<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <!-- EN-TETE toujours visible -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Rattrapages"
            android:textColor="@color/widget_gold"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_qada_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 0 jours"
            android:textColor="@color/widget_text_status"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- ETAT : pas de programme -->
    <LinearLayout
        android:id="@+id/ll_no_program"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pas de programme\nde rattrapage\npour le moment"
            android:textColor="@color/widget_text_muted"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>

    <!-- ETAT : programme actif -->
    <LinearLayout
        android:id="@+id/ll_has_program"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Espace flexible au-dessus de la barre -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- BARRE DE PROGRESSION + compteur aujourd'hui -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="12dp"
                android:layout_weight="1"
                android:layout_marginRight="12dp">
                <ImageView
                    android:id="@+id/img_qada_bar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_qada_today"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 5"
                android:textColor="@color/widget_gold"
                android:textSize="13sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_qada_estimate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="~14 jours à ce rythme"
            android:textColor="@color/widget_text_muted"
            android:textSize="11sp"
            android:layout_marginTop="5dp"/>

        <!-- Espace flexible sous la barre -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- RESTANT PAR PRIERE — collé en bas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Fajr" android:textColor="@color/widget_text_muted" android:textSize="12sp" android:layout_marginBottom="3dp"/>
                <TextView android:id="@+id/tv_rem_fajr" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/widget_prayer_time" android:textSize="22sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Dhuhr" android:textColor="@color/widget_text_muted" android:textSize="12sp" android:layout_marginBottom="3dp"/>
                <TextView android:id="@+id/tv_rem_dhuhr" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/widget_prayer_time" android:textSize="22sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Asr" android:textColor="@color/widget_text_muted" android:textSize="12sp" android:layout_marginBottom="3dp"/>
                <TextView android:id="@+id/tv_rem_asr" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/widget_prayer_time" android:textSize="22sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Maghrib" android:textColor="@color/widget_text_muted" android:textSize="12sp" android:layout_marginBottom="3dp"/>
                <TextView android:id="@+id/tv_rem_maghrib" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/widget_prayer_time" android:textSize="22sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Isha" android:textColor="@color/widget_text_muted" android:textSize="12sp" android:layout_marginBottom="3dp"/>
                <TextView android:id="@+id/tv_rem_isha" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/widget_prayer_time" android:textSize="22sp" android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
